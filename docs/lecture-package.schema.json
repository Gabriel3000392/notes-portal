{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notes-portal.local/lecture-package.schema.json",
  "title": "Lecture Package",
  "type": "object",
  "required": ["source", "course", "lecture", "notes", "studyAssets"],
  "properties": {
    "source": {
      "type": "object",
      "required": ["system", "id"],
      "properties": {
        "system": { "type": "string", "enum": ["echo360", "manual"] },
        "id": { "type": "string" },
        "downloadedAt": { "type": "string" }
      }
    },
    "course": {
      "type": "object",
      "required": ["code", "title", "term"],
      "properties": {
        "code": { "type": "string" },
        "title": { "type": "string" },
        "term": { "type": "string" }
      }
    },
    "lecture": {
      "type": "object",
      "required": ["slug", "title", "date"],
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "subtitle": { "type": "string" }
      }
    },
    "notes": {
      "type": "object",
      "required": ["contentHtml"],
      "properties": {
        "contentHtml": { "type": "string" },
        "contentMarkdown": { "type": "string" }
      }
    },
    "studyAssets": {
      "type": "object",
      "properties": {
        "tags": { "type": "array", "items": { "type": "string" } },
        "flashcards": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["front", "back"],
            "properties": {
              "front": { "type": "string" },
              "back": { "type": "string" },
              "difficultySeed": { "type": "string" }
            }
          }
        },
        "quizzes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "questions"],
            "properties": {
              "title": { "type": "string" },
              "questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["type", "prompt", "correctAnswer", "explanation"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["multiple_choice", "short_answer"]
                    },
                    "prompt": { "type": "string" },
                    "options": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "correctAnswer": { "type": "string" },
                    "explanation": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "studyGuides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "content"],
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
